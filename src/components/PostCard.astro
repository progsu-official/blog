---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, date, author, tags, description } = post.data;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article
  class="group rounded-sm border border-accent-purple/30 bg-bg-mid/40 p-6 transition-all duration-200 hover:border-accent-pink/60 hover:bg-bg-mid/60"
  style="transition: box-shadow 0.2s;"
  onmouseenter="this.style.boxShadow='0 0 16px rgba(214,58,175,0.25)'"
  onmouseleave="this.style.boxShadow='none'"
>
  <a href={`/posts/${post.slug}`} class="block space-y-3">
    <div class="flex items-center gap-3 font-vt text-base text-steel-blue">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="text-accent-purple">//</span>
      <span>{author}</span>
    </div>

    <h2 class="font-pixel text-xs leading-relaxed text-lavender group-hover:text-accent-cyan transition-colors duration-200">
      {title}
    </h2>

    <p class="font-vt text-lg leading-snug text-steel-blue">{description}</p>

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-1">
          {tags.map((tag) => (
            <span class="rounded-sm border border-accent-purple/50 bg-accent-purple/10 px-2 py-0.5 font-pixel text-[9px] text-accent-purple">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </a>
</article>
