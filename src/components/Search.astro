---
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).map((p) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
  date: p.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }),
}));
---

<!-- Search overlay -->
<div id="search-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search posts">
  <div id="search-box">
    <div id="search-input-row">
      <span id="search-prompt">&#47;</span>
      <input
        id="search-input"
        type="text"
        placeholder="search posts..."
        autocomplete="off"
        spellcheck="false"
      />
      <kbd id="search-esc">esc</kbd>
    </div>
    <ul id="search-results" role="listbox"></ul>
    <p id="search-empty" aria-live="polite"></p>
  </div>
</div>

<script define:vars={{ posts }}>
  const overlay   = document.getElementById("search-overlay");
  const input     = document.getElementById("search-input");
  const results   = document.getElementById("search-results");
  const emptyMsg  = document.getElementById("search-empty");

  function open() {
    overlay.setAttribute("aria-hidden", "false");
    overlay.classList.add("open");
    input.value = "";
    renderResults("");
    requestAnimationFrame(() => input.focus());
  }

  function close() {
    overlay.setAttribute("aria-hidden", "true");
    overlay.classList.remove("open");
    results.innerHTML = "";
    emptyMsg.textContent = "";
  }

  function normalize(str) {
    return str.toLowerCase().replace(/[^a-z0-9 ]/g, " ");
  }

  function renderResults(query) {
    results.innerHTML = "";
    emptyMsg.textContent = "";

    const q = normalize(query.trim());

    const matched = q.length === 0
      ? posts
      : posts.filter((p) => {
          const haystack = normalize(
            [p.title, p.description, ...p.tags].join(" ")
          );
          return q.split(" ").every((word) => word === "" || haystack.includes(word));
        });

    if (matched.length === 0) {
      emptyMsg.textContent = "no results.";
      return;
    }

    matched.forEach((p, i) => {
      const li = document.createElement("li");
      li.setAttribute("role", "option");
      li.setAttribute("data-index", i);
      li.innerHTML = `
        <a href="/posts/${p.slug}">
          <span class="r-title">${p.title}</span>
        </a>
      `;
      results.appendChild(li);
    });
  }

  // Keyboard: open on "/", close on Escape, arrow nav
  document.addEventListener("keydown", (e) => {
    const tag = document.activeElement?.tagName;
    if (e.key === "/" && tag !== "INPUT" && tag !== "TEXTAREA") {
      e.preventDefault();
      open();
      return;
    }
    if (e.key === "Escape") { close(); return; }

    if (!overlay.classList.contains("open")) return;

    const items = results.querySelectorAll("li");
    const active = results.querySelector("li.active");
    let idx = active ? parseInt(active.dataset.index) : -1;

    if (e.key === "ArrowDown") {
      e.preventDefault();
      idx = Math.min(idx + 1, items.length - 1);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      idx = Math.max(idx - 1, 0);
    } else if (e.key === "Enter" && active) {
      active.querySelector("a")?.click();
      return;
    } else { return; }

    items.forEach((li) => li.classList.remove("active"));
    if (items[idx]) {
      items[idx].classList.add("active");
      items[idx].scrollIntoView({ block: "nearest" });
    }
  });

  input.addEventListener("input", () => renderResults(input.value));

  // Click outside to close
  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) close();
  });

  // Close button (esc badge)
  document.getElementById("search-esc").addEventListener("click", close);

  // Navbar "/" badge
  document.getElementById("search-trigger")?.addEventListener("click", (e) => {
    e.preventDefault();
    open();
  });
</script>

<style>
  #search-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(2, 2, 10, 0.75);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 8rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  #search-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  #search-box {
    width: 100%;
    max-width: 600px;
    margin: 0 1.5rem;
    background: rgba(6, 6, 15, 0.95);
    border: 1px solid rgba(168, 85, 247, 0.25);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(76, 29, 149, 0.3), 0 8px 32px rgba(0, 0, 0, 0.6);
  }

  #search-input-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(168, 85, 247, 0.12);
  }

  #search-prompt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(168, 85, 247, 0.6);
    flex-shrink: 0;
  }

  #search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
    caret-color: rgba(168, 85, 247, 0.8);
  }

  #search-input::placeholder {
    color: rgba(255, 255, 255, 0.2);
  }

  #search-esc {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.2rem 0.45rem;
    border-radius: 3px;
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  #search-esc:hover {
    color: rgba(255, 255, 255, 0.55);
    border-color: rgba(255, 255, 255, 0.3);
  }

  #search-results {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0;
    max-height: 320px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(168, 85, 247, 0.3) transparent;
  }

  #search-results li a {
    display: block;
    padding: 0.6rem 1rem;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.65);
    transition: color 0.1s ease, background 0.1s ease;
  }

  #search-results li:hover a,
  #search-results li.active a {
    color: rgba(216, 180, 254, 0.9);
    background: rgba(76, 29, 149, 0.15);
  }

  #search-empty {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.25);
    text-align: center;
    padding: 1.5rem 1rem;
    letter-spacing: 0.08em;
  }
</style>
