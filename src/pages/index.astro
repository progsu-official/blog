---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout>
  <section class="mb-12 space-y-2">
    <h1 class="text-3xl font-bold text-lavender">
      ProgSU <span class="text-accent-cyan glow-cyan">Blog</span>
    </h1>
    <p class="text-steel-blue">{SITE_DESCRIPTION}</p>
  </section>

  {
    posts.length === 0 ? (
      <p class="text-steel-blue">No posts yet — check back soon.</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )
  }
</Layout>
