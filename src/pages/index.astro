---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);

// Group by season, preserving chronological order within each season
const seasonMap = new Map<string, typeof posts>();
for (const post of posts) {
  const key = post.data.season ?? "other";
  if (!seasonMap.has(key)) seasonMap.set(key, []);
  seasonMap.get(key)!.push(post);
}

// Sort seasons by latest post date descending (most recent season first)
const seasons = [...seasonMap.entries()].sort((a, b) => {
  const latestA = Math.max(...a[1].map((p) => p.data.date.valueOf()));
  const latestB = Math.max(...b[1].map((p) => p.data.date.valueOf()));
  return latestB - latestA;
});
---

<Layout>

  <!-- ═══════════════════════════════════════════════════
       HERO — Section 5B
  ═══════════════════════════════════════════════════ -->
  <section id="hero">
    <div class="hero-inner float-in">
      <h1 class="hero-headline">progsu / blog</h1>
      <p class="hero-desc">{SITE_DESCRIPTION}</p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       POSTS — grouped by season
  ═══════════════════════════════════════════════════ -->
  <section id="posts">

    {seasons.length === 0 ? (
      <p class="empty-state float-in">no posts yet. check back soon.</p>
    ) : (
      seasons.map(([season, seasonPosts], i) => (
        <details class="season-group float-in" open={i === 0 ? true : undefined}>
          <summary class="season-header">
            <span class="season-label">{season}</span>
            <span class="season-meta">{seasonPosts.length} {seasonPosts.length === 1 ? "post" : "posts"}</span>
            <span class="season-arrow" aria-hidden="true">↓</span>
          </summary>
          <div class="season-posts">
            {seasonPosts.map((post) => <PostCard post={post} />)}
          </div>
        </details>
      ))
    )}

    <div class="back-link-wrap float-in">
      <a
        href="https://progsu.com"
        class="back-link"
        style="text-shadow: 0 0 8px rgba(147,51,234,0);"
        onmouseover="this.style.color='rgba(255,255,255,1)';this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';"
        onmouseout="this.style.color='rgba(255,255,255,0.55)';this.style.textShadow='0 0 8px rgba(147,51,234,0)';"
      >
        ← back to home
      </a>
    </div>

  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  #hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
    padding: 0 2rem;
  }

  .hero-headline {
    font-family: 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #fff;
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,.65);
    line-height: 1.7;
    max-width: 40ch;
    margin: 0 auto;
  }

  /* ── Posts ────────────────────────────────────────────── */
  #posts {
    padding-top: 4rem;
    padding-bottom: 8rem;
  }

  /* ── Season toggle ────────────────────────────────────── */
  .season-group {
    border-top: 1px solid rgba(255,255,255,.06);
    margin-bottom: 0;
  }

  .season-group:last-of-type .season-posts {
    border-bottom: none;
  }

  .season-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  /* Remove default disclosure triangle */
  .season-header::-webkit-details-marker { display: none; }
  .season-header::marker { display: none; }

  .season-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,.65);
    flex: 1;
  }

  .season-meta {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,.30);
  }

  .season-arrow {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    color: rgba(255,255,255,.30);
    transition: transform 0.25s ease, color 0.2s;
    display: inline-block;
  }

  .season-group[open] .season-arrow {
    transform: rotate(180deg);
  }

  .season-header:hover .season-label {
    color: rgba(255,255,255,.90);
  }

  .season-header:hover .season-arrow {
    color: rgba(255,255,255,.55);
  }

  .season-posts {
    padding-bottom: 1.5rem;
  }

  /* ── Misc ─────────────────────────────────────────────── */
  .empty-state {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255,255,255,.55);
    padding: 4rem 0;
  }

  .back-link-wrap {
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,.05);
    margin-top: 1rem;
  }

  .back-link {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    transition: color .3s, text-shadow .3s;
  }
</style>
