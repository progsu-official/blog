---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout>
  <section class="mb-14 space-y-4">
    <h1 class="font-pixel text-lg leading-loose text-lavender">
      ProgSU <span class="text-accent-cyan glow-cyan">Blog</span>
    </h1>
    <p class="font-vt text-xl text-steel-blue">{SITE_DESCRIPTION}</p>
    <div class="h-px w-24 bg-accent-pink" style="box-shadow: 0 0 8px rgba(214,58,175,0.6);"></div>
  </section>

  {
    posts.length === 0 ? (
      <p class="font-vt text-xl text-steel-blue">No posts yet — check back soon.</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )
  }
</Layout>
