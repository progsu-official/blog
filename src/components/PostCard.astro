---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, date, description } = post.data;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/posts/${post.slug}`} class="post-card-link float-in group">
  <div class="post-card">
    <div class="post-card-body">
      <h2 class="post-title">{title.toLowerCase()}</h2>
      {description && <p class="post-desc">{description}</p>}
      <time class="post-date" datetime={date.toISOString()}>{formattedDate.toLowerCase()}</time>
    </div>
    <span class="post-arrow">→</span>
  </div>
</a>

<style>
  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
    padding: 1.75rem 0;
    transition: border-color 0.3s;
  }

  .post-card-link:hover .post-card {
    border-color: rgba(255, 255, 255, 0.25);
  }

  .post-card-body {
    flex: 1;
    min-width: 0;
  }

  .post-title {
    font-family: 'Noto Serif', Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 1.125rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 1);
    margin-bottom: 0.4rem;
    line-height: 1.4;
    transition: color 0.3s;
  }

  .post-card-link:hover .post-title {
    color: rgba(255, 255, 255, 1);
  }

  .post-desc {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.70);
    line-height: 1.6;
    margin-bottom: 0.6rem;
  }

  .post-date {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.50);
  }

  .post-arrow {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.45);
    flex-shrink: 0;
    margin-left: 1.5rem;
    margin-top: 0.2rem;
    transition: color 0.3s;
  }

  .post-card-link:hover .post-arrow {
    color: rgba(255, 255, 255, 0.80);
  }
</style>
