---
import { NAV_LINKS, SITE_TITLE } from "@/consts";
---

<header class="sticky top-0 z-50 border-b border-bg-mid bg-bg-deep/90 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-sm font-semibold text-accent-cyan glow-cyan hover:opacity-80 transition-opacity">
      {SITE_TITLE}
    </a>
    <ul class="flex items-center gap-6">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-steel-blue hover:text-lavender transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
