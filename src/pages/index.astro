---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);

// Group by season, preserving chronological order within each season
const seasonMap = new Map<string, typeof posts>();
for (const post of posts) {
  const key = post.data.season ?? "other";
  if (!seasonMap.has(key)) seasonMap.set(key, []);
  seasonMap.get(key)!.push(post);
}

// Sort seasons by latest post date descending (most recent season first)
const seasons = [...seasonMap.entries()].sort((a, b) => {
  const latestA = Math.max(...a[1].map((p) => p.data.date.valueOf()));
  const latestB = Math.max(...b[1].map((p) => p.data.date.valueOf()));
  return latestB - latestA;
});
---

<Layout>

  <!-- ═══════════════════════════════════════════════════
       HERO — Section 5B
  ═══════════════════════════════════════════════════ -->
  <section id="hero">
    <div class="hero-inner float-in">
      <h1 class="hero-headline">progsu / blog</h1>
      <p class="hero-desc">{SITE_DESCRIPTION}</p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       SPRING RECAP MAGAZINE
  ═══════════════════════════════════════════════════ -->
  <section id="magazine" class="float-in">
    <div class="mag-header">
      <h2 class="mag-title">spring 2026 recap</h2>
      <span class="mag-label">magazine</span>
    </div>
    <div class="mag-track" id="mag-track" role="region" aria-label="Spring 2026 recap magazine">
      {[1,2,3,4,5,6,7,8].map((n) => (
        <div class="mag-slide">
          <img
            src={`/images/spring-2026/magazine/page-${n}.jpg`}
            alt={`spring 2026 recap — page ${n}`}
            loading={n === 1 ? "eager" : "lazy"}
            draggable="false"
          />
        </div>
      ))}
    </div>
    <div class="mag-dots" id="mag-dots" aria-hidden="true">
      {[1,2,3,4,5,6,7,8].map((n) => (
        <button class={`mag-dot${n === 1 ? " active" : ""}`} data-index={n - 1} aria-label={`Go to page ${n}`} />
      ))}
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       POSTS — grouped by season
  ═══════════════════════════════════════════════════ -->
  <section id="posts">

    {seasons.length === 0 ? (
      <p class="empty-state float-in">no posts yet. check back soon.</p>
    ) : (
      seasons.map(([season, seasonPosts], i) => (
        <details class="season-group float-in" open={i === 0 ? true : undefined}>
          <summary class="season-header">
            <span class="season-label">{season}</span>
            <span class="season-meta">{seasonPosts.length} {seasonPosts.length === 1 ? "post" : "posts"}</span>
            <span class="season-arrow" aria-hidden="true">↓</span>
          </summary>
          <div class="season-posts">
            {seasonPosts.map((post) => <PostCard post={post} />)}
          </div>
        </details>
      ))
    )}

    <div class="back-link-wrap float-in">
      <a
        href="https://progsu.com"
        class="back-link"
        style="text-shadow: 0 0 8px rgba(147,51,234,0);"
        onmouseover="this.style.color='rgba(255,255,255,1)';this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';"
        onmouseout="this.style.color='rgba(255,255,255,0.55)';this.style.textShadow='0 0 8px rgba(147,51,234,0)';"
      >
        ← back to home
      </a>
    </div>

  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  #hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
    padding: 0 2rem;
  }

  .hero-headline {
    font-family: 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #fff;
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,.65);
    line-height: 1.7;
    max-width: 40ch;
    margin: 0 auto;
  }

  /* ── Magazine carousel ───────────────────────────────── */
  #magazine {
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
    margin-bottom: 0;
  }

  .mag-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
    margin-bottom: 1.5rem;
  }

  .mag-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,.65);
    margin: 0;
  }

  .mag-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,.30);
  }

  .mag-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    gap: 0.75rem;
    scrollbar-width: none;
    cursor: grab;
  }

  .mag-track::-webkit-scrollbar { display: none; }
  .mag-track:active { cursor: grabbing; }

  .mag-slide {
    flex: 0 0 auto;
    width: calc(50% - 0.375rem);
    scroll-snap-align: start;
    border-radius: 4px;
    overflow: hidden;
    background: rgba(255,255,255,.03);
  }

  .mag-slide img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  .mag-dots {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    margin-top: 1.25rem;
  }

  .mag-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,.20);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .mag-dot.active {
    background: rgba(255,255,255,.75);
    transform: scale(1.3);
  }

  /* ── Posts ────────────────────────────────────────────── */
  #posts {
    padding-top: 4rem;
    padding-bottom: 8rem;
  }

  /* ── Season toggle ────────────────────────────────────── */
  .season-group {
    border-top: 1px solid rgba(255,255,255,.06);
    margin-bottom: 0;
  }

  .season-group:last-of-type .season-posts {
    border-bottom: none;
  }

  .season-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  /* Remove default disclosure triangle */
  .season-header::-webkit-details-marker { display: none; }
  .season-header::marker { display: none; }

  .season-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,.65);
    flex: 1;
  }

  .season-meta {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,.30);
  }

  .season-arrow {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    color: rgba(255,255,255,.30);
    transition: transform 0.25s ease, color 0.2s;
    display: inline-block;
  }

  .season-group[open] .season-arrow {
    transform: rotate(180deg);
  }

  .season-header:hover .season-label {
    color: rgba(255,255,255,.90);
  }

  .season-header:hover .season-arrow {
    color: rgba(255,255,255,.55);
  }

  .season-posts {
    padding-bottom: 1.5rem;
  }

  /* ── Misc ─────────────────────────────────────────────── */
  .empty-state {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255,255,255,.55);
    padding: 4rem 0;
  }

  .back-link-wrap {
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,.05);
    margin-top: 1rem;
  }

  .back-link {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    transition: color .3s, text-shadow .3s;
  }
</style>

<script>
  const track = document.getElementById("mag-track");
  const dots  = document.querySelectorAll(".mag-dot");
  const total = dots.length;
  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let paused = false;

  function goTo(index: number) {
    const slide = track?.children[index] as HTMLElement | undefined;
    if (!slide || !track) return;
    track.scrollTo({ left: slide.offsetLeft, behavior: "smooth" });
    dots.forEach((d, i) => d.classList.toggle("active", i === index));
    current = index;
  }

  function next() {
    goTo((current + 1) % total);
  }

  function startTimer() {
    timer = setInterval(next, 4000);
  }

  function stopTimer() {
    if (timer) { clearInterval(timer); timer = null; }
  }

  // Dot clicks
  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => { goTo(i); stopTimer(); startTimer(); });
  });

  // Pause on hover / touch
  track?.addEventListener("mouseenter", () => { paused = true; stopTimer(); });
  track?.addEventListener("mouseleave", () => { paused = false; startTimer(); });
  track?.addEventListener("touchstart",  () => { paused = true; stopTimer(); }, { passive: true });
  track?.addEventListener("touchend",    () => { setTimeout(() => { paused = false; startTimer(); }, 2000); });

  // Sync dots on manual scroll
  track?.addEventListener("scroll", () => {
    if (!track) return;
    const slideW = (track.children[0] as HTMLElement)?.offsetWidth + 12;
    const idx = Math.round(track.scrollLeft / slideW);
    if (idx !== current) {
      dots.forEach((d, i) => d.classList.toggle("active", i === idx));
      current = idx;
    }
  }, { passive: true });

  startTimer();
</script>
