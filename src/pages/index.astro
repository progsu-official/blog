---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featured = posts[0];
const rest = posts.slice(1);
---

<Layout>
  <section class="hero">
    <h1 class="hero-title">progsu / blog</h1>
    <p class="hero-desc">{SITE_DESCRIPTION}</p>
  </section>

  <hr class="divider" />

  {
    posts.length === 0 ? (
      <p class="empty">no posts yet. check back soon.</p>
    ) : (
      <div class="post-list">
        {featured && (
          <a href={`/posts/${featured.slug}`} class="featured-link">
            <article class="featured-card">
              <div class="featured-label">latest</div>
              <h2 class="featured-title">{featured.data.title}</h2>
              <p class="featured-desc">{featured.data.description}</p>
              <time class="featured-date" datetime={featured.data.date.toISOString()}>
                {featured.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
              </time>
            </article>
          </a>
        )}

        {rest.length > 0 && (
          <div class="rest-list">
            {rest.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        )}
      </div>
    )
  }
</Layout>

<style>
  .hero {
    margin-bottom: 2.5rem;
  }

  .hero-title {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .hero-desc {
    font-size: 0.75rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.38);
    max-width: 52ch;
  }

  .divider {
    border: none;
    border-top: 1px solid rgba(168, 85, 247, 0.12);
    margin-bottom: 2rem;
  }

  /* ── Featured card ── */
  .featured-link {
    display: block;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .featured-card {
    padding: 0.85rem 1.1rem;
    border: 1px solid rgba(168, 85, 247, 0.12);
    border-radius: 4px;
    background: transparent;
    transition: border-color 0.2s ease;
  }

  .featured-link:hover .featured-card {
    border-color: rgba(168, 85, 247, 0.25);
  }

  .featured-label {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.4);
    margin-bottom: 0.6rem;
  }

  .featured-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.5rem;
    line-height: 1.5;
    transition: color 0.15s ease;
  }

  .featured-link:hover .featured-title {
    color: rgba(216, 180, 254, 0.85);
  }

  .featured-desc {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.28);
    line-height: 1.7;
    margin-bottom: 0.85rem;
  }

  .featured-date {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.2);
  }

  .rest-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .empty {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.28);
    letter-spacing: 0.08em;
  }
</style>
