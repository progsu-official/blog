---
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
const pageTitle = title === SITE_TITLE ? title : `${title} — ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Mid stars layer (1.5px dots with lavender/sky tints) -->
    <div id="stars-mid" aria-hidden="true"></div>
    <!-- Vignette -->
    <div id="vignette" aria-hidden="true"></div>

    <!-- All content sits at z-index 1 above the background layers -->
    <div style="position: relative; z-index: 1; display: flex; flex-direction: column; min-height: 100vh;">
      <Navbar />
      <main style="max-width: 760px; width: 100%; margin: 0 auto; padding: 6rem 1.5rem 4rem; flex: 1;">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
