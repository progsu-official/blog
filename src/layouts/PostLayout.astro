---
import Layout from "./Layout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, date, author, tags, description } = post.data;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={title} description={description}>
  <article>
    <header class="mb-10 space-y-4 border-b border-bg-mid pb-8">
      <div class="flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="rounded border border-accent-purple/40 bg-accent-purple/10 px-2 py-0.5 font-mono text-xs text-accent-purple">
              #{tag}
            </span>
          ))
        }
      </div>
      <h1 class="text-3xl font-bold leading-tight text-lavender">{title}</h1>
      <p class="text-base text-steel-blue">{description}</p>
      <div class="flex items-center gap-3 text-sm text-steel-blue">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span>&middot;</span>
        <span>{author}</span>
      </div>
    </header>

    <div class="prose prose-invert max-w-none prose-code:font-mono prose-pre:border prose-pre:border-bg-mid">
      <slot />
    </div>
  </article>
</Layout>
