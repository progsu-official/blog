---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const postCount = posts.length;
---

<Layout>

  <!-- ═══════════════════════════════════════════════════
       HERO — Section 5B
  ═══════════════════════════════════════════════════ -->
  <section id="hero">
    <div class="hero-inner float-in">
      <h1 class="hero-headline">progsu / blog</h1>
      <p class="hero-desc">{SITE_DESCRIPTION}</p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       POSTS
  ═══════════════════════════════════════════════════ -->
  <section id="posts">

    <h2 class="section-heading float-in">posts</h2>

    {
      posts.length === 0 ? (
        <p class="empty-state float-in">no posts yet. check back soon.</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      )
    }

    <div class="back-link-wrap float-in">
      <a
        href="https://progsu.com"
        class="back-link"
        style="text-shadow: 0 0 8px rgba(147,51,234,0);"
        onmouseover="this.style.color='rgba(255,255,255,1)';this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';"
        onmouseout="this.style.color='rgba(255,255,255,0.40)';this.style.textShadow='0 0 8px rgba(147,51,234,0)';"
      >
        ← back to home
      </a>
    </div>

  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  #hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
    padding: 0 2rem;
  }

  .hero-headline {
    font-family: 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #fff;
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255,255,255,.50);
    line-height: 1.7;
    max-width: 40ch;
    margin: 0 auto;
  }

  /* ── Posts ────────────────────────────────────────────── */
  #posts {
    padding-top: 4rem;
    padding-bottom: 8rem;
  }

  .section-heading {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,.40);
    margin: 0 0 0 0;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(255,255,255,.30);
    padding: 4rem 0;
  }

  .back-link-wrap {
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,.05);
    margin-top: 1rem;
  }

  .back-link {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,.40);
    text-decoration: none;
    transition: color .3s, text-shadow .3s;
  }
</style>
