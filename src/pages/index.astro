---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group by season, preserving chronological order within each season
const seasonMap = new Map<string, typeof posts>();
for (const post of posts) {
  const key = post.data.season ?? "other";
  if (!seasonMap.has(key)) seasonMap.set(key, []);
  seasonMap.get(key)!.push(post);
}

// Sort seasons by latest post date descending (most recent season first)
const seasons = [...seasonMap.entries()].sort((a, b) => {
  const latestA = Math.max(...a[1].map((p) => p.data.date.valueOf()));
  const latestB = Math.max(...b[1].map((p) => p.data.date.valueOf()));
  return latestB - latestA;
});
---

<Layout>

  <!-- ═══════════════════════════════════════════════════
       HERO — Section 5B
  ═══════════════════════════════════════════════════ -->
  <section id="hero">
    <div class="hero-inner float-in">
      <h1 class="hero-headline">progsu / blog</h1>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       SPRING 2026 RECAP — single toggle for magazine + posts
  ═══════════════════════════════════════════════════ -->
  <details class="season-wrap float-in" open>
    <summary class="season-header">
      <span class="season-label">spring 2026 recap</span>
      <span class="season-meta">magazine</span>
      <span class="season-arrow" aria-hidden="true">↓</span>
    </summary>

    <!-- Magazine carousel -->
    <div id="magazine">
      <div class="mag-carousel-wrap">
        <button class="mag-prev" id="mag-prev" aria-label="Previous page">&#8249;</button>
        <div class="mag-track" id="mag-track" role="region" aria-label="Spring 2026 recap magazine">
          {[1,2,3,4,5,6,7,8].map((n) => (
            <div class="mag-slide">
              <img
                src={`/images/spring-2026/magazine/page-${n}.jpg`}
                alt={`spring 2026 recap, page ${n}`}
                loading={n === 1 ? "eager" : "lazy"}
                draggable="false"
                data-page={n}
              />
            </div>
          ))}
        </div>
        <button class="mag-next" id="mag-next" aria-label="Next page">&#8250;</button>
      </div>
      <div class="mag-dots" id="mag-dots" aria-hidden="true">
        {[1,2,3,4].map((n) => (
          <button class={`mag-dot${n === 1 ? " active" : ""}`} data-index={n - 1} aria-label={`Go to page ${n}`} />
        ))}
      </div>
    </div>


    <!-- Posts list -->
    {posts.length === 0 ? (
      <p class="empty-state">no posts yet. check back soon.</p>
    ) : (
      <div class="season-posts">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    )}

  </details>

  <!-- Lightbox — must live outside .float-in to keep position:fixed relative to viewport -->
  <div id="mag-lightbox" aria-hidden="true" aria-modal="true" role="dialog">
    <button id="mag-lb-close" aria-label="Close">&#10005;</button>
    <img id="mag-lb-img" src="" alt="" />
  </div>

  <div class="back-link-wrap float-in">
    <a
      href="https://progsu.com"
      class="back-link"
      style="text-shadow: 0 0 8px rgba(147,51,234,0);"
      onmouseover="this.style.color='rgba(255,255,255,1)';this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';"
      onmouseout="this.style.color='rgba(255,255,255,0.55)';this.style.textShadow='0 0 8px rgba(147,51,234,0)';"
    >
      ← back to home
    </a>
  </div>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  #hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
    padding: 0 2rem;
  }

  .hero-headline {
    font-family: 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #fff;
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,.65);
    line-height: 1.7;
    max-width: 40ch;
    margin: 0 auto;
  }

  /* ── Magazine carousel ───────────────────────────────── */
  #magazine {
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
    margin-bottom: 0;
  }

  .mag-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,.50);
  }

  .mag-carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mag-prev, .mag-next {
    flex: 0 0 auto;
    background: none;
    border: none;
    color: rgba(255,255,255,.60);
    font-size: 2.25rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.5rem 0.4rem;
    transition: color 0.2s;
    user-select: none;
  }

  .mag-prev:hover, .mag-next:hover { color: rgba(255,255,255,.80); }

  .mag-track {
    flex: 1;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    gap: 0.75rem;
    scrollbar-width: none;
    cursor: grab;
  }

  .mag-track::-webkit-scrollbar { display: none; }
  .mag-track:active { cursor: grabbing; }

  .mag-slide {
    flex: 0 0 auto;
    width: calc(50% - 0.375rem);
    scroll-snap-align: start;
    border-radius: 4px;
    overflow: hidden;
    background: rgba(255,255,255,.03);
  }

  .mag-slide img {
    width: 100%;
    height: auto;
    display: block;
    cursor: zoom-in;
    user-select: none;
  }

  /* ── Lightbox ─────────────────────────────────────────── */
  #mag-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(0,0,0,.80);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    align-items: center;
    justify-content: center;
  }

  #mag-lightbox.open {
    display: flex;
  }

  #mag-lb-img {
    max-width: 88vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 0 80px rgba(0,0,0,.6);
  }

  #mag-lb-close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255,255,255,.55);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s;
    z-index: 1000;
  }

  #mag-lb-close:hover { color: #fff; }

  .mag-dots {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    margin-top: 1.25rem;
  }

  .mag-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,.20);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .mag-dot.active {
    background: rgba(255,255,255,.75);
    transform: scale(1.3);
  }

  /* ── Season wrap + toggle ─────────────────────────────── */
  .season-wrap {
    border-top: 1px solid rgba(255,255,255,.06);
    padding-bottom: 8rem;
  }

  .season-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  /* Remove default disclosure triangle */
  .season-header::-webkit-details-marker { display: none; }
  .season-header::marker { display: none; }

  .season-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,.80);
    flex: 1;
  }

  .season-meta {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,.50);
  }

  .season-arrow {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    color: rgba(255,255,255,.30);
    transition: transform 0.25s ease, color 0.2s;
    display: inline-block;
  }

  .season-wrap[open] .season-arrow {
    transform: rotate(180deg);
  }

  .season-header:hover .season-label {
    color: rgba(255,255,255,.90);
  }

  .season-header:hover .season-arrow {
    color: rgba(255,255,255,.55);
  }

  .season-posts {
    padding-bottom: 1.5rem;
  }

  /* ── Misc ─────────────────────────────────────────────── */
  .empty-state {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255,255,255,.55);
    padding: 4rem 0;
  }

  .back-link-wrap {
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,.05);
    margin-top: 1rem;
  }

  .back-link {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    transition: color .3s, text-shadow .3s;
  }
</style>

<script>
  const track    = document.getElementById("mag-track");
  const dots     = document.querySelectorAll(".mag-dot");
  const PAGES    = 4;
  const PER_PAGE = 2;
  let current    = 0;
  let scrolling  = false;
  let autoActive = false;
  let autoTimer: ReturnType<typeof setTimeout> | null = null;
  let idleTimer: ReturnType<typeof setTimeout> | null = null;

  function goTo(page: number) {
    const p = (page + PAGES) % PAGES;
    const slide = track?.children[p * PER_PAGE] as HTMLElement | undefined;
    if (!slide || !track) return;
    scrolling = true;
    track.scrollTo({ left: slide.offsetLeft, behavior: "smooth" });
    dots.forEach((d, i) => d.classList.toggle("active", i === p));
    current = p;
    setTimeout(() => { scrolling = false; }, 700);
  }

  function scheduleNext() {
    if (!autoActive) return;
    autoTimer = setTimeout(() => {
      goTo(current + 1);
      scheduleNext();
    }, 6000);
  }

  function startAuto() {
    autoActive = true;
    scheduleNext();
  }

  function stopAuto() {
    autoActive = false;
    if (autoTimer) { clearTimeout(autoTimer); autoTimer = null; }
  }

  // Stop autoplay on manual interaction, restart after 10 s of inactivity
  function onManual() {
    stopAuto();
    if (idleTimer) clearTimeout(idleTimer);
    idleTimer = setTimeout(startAuto, 10000);
  }

  // Dot clicks
  dots.forEach((dot, i) => dot.addEventListener("click", () => { goTo(i); onManual(); }));

  // Prev / next buttons
  document.getElementById("mag-prev")?.addEventListener("click", () => { goTo(current - 1); onManual(); });
  document.getElementById("mag-next")?.addEventListener("click", () => { goTo(current + 1); onManual(); });

  // Keyboard left / right
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "ArrowRight") { goTo(current + 1); onManual(); }
    if (e.key === "ArrowLeft")  { goTo(current - 1); onManual(); }
    if (e.key === "Escape")     closeLightbox();
  });

  // Lightbox
  const lightbox = document.getElementById("mag-lightbox");
  const lbImg    = document.getElementById("mag-lb-img") as HTMLImageElement | null;

  function openLightbox(src: string, alt: string) {
    if (!lightbox || !lbImg) return;
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.classList.add("open");
    lightbox.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox?.classList.remove("open");
    lightbox?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  track?.querySelectorAll(".mag-slide img").forEach((img) => {
    img.addEventListener("click", () => {
      const el = img as HTMLImageElement;
      openLightbox(el.src, el.alt);
    });
  });

  document.getElementById("mag-lb-close")?.addEventListener("click", closeLightbox);
  lightbox?.addEventListener("click", (e) => { if (e.target === lightbox) closeLightbox(); });

  // Sync dots on manual drag scroll only
  track?.addEventListener("scroll", () => {
    if (scrolling || !track) return;
    const slideW = (track.children[0] as HTMLElement)?.offsetWidth + 12;
    const page   = Math.min(Math.round(track.scrollLeft / slideW / PER_PAGE), PAGES - 1);
    if (page !== current) {
      dots.forEach((d, i) => d.classList.toggle("active", i === page));
      current = page;
      onManual();
    }
  }, { passive: true });

  startAuto();
</script>
