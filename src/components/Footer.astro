---
const year = new Date().getFullYear();
---

<footer>
  <!-- Binary texture background -->
  <div class="binary-bg" aria-hidden="true">
    {Array.from({ length: 6 }).map(() => (
      <div class="binary-row">01001010 01100001 01110110 01100001 01010011 01100011 01110010 01101001 01110000 01110100 00100000 01100010 01110101 01101001 01101100 01100100 01100101 01110010 01110011 00100000 01100010 01110101 01101001 01101100 01100100 01101001 01101110 01100111 00100000 01100001 01110100 00100000 01000111 01010011 01010101</div>
    ))}
  </div>

  <div class="footer-inner">
    <!-- Social links row -->
    <div class="social-links">
      {[
        { label: "discord",   href: "https://discord.gg/BgKg9gskM2" },
        { label: "instagram", href: "https://www.instagram.com/progsuhq/" },
        { label: "linkedin",  href: "https://www.linkedin.org/company/progsu" },
        { label: "email",     href: "mailto:official@progsu.com" },
      ].map((l) => (
        <a
          href={l.href}
          class="social-link"
          style="text-shadow: 0 0 8px rgba(147,51,234,0); transition: color 0.3s, text-shadow 0.3s;"
          onmouseover="this.style.color='rgba(255,255,255,1)';this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';"
          onmouseout="this.style.color='rgba(255,255,255,0.70)';this.style.textShadow='0 0 8px rgba(147,51,234,0)';"
        >
          {l.label}
        </a>
      ))}
    </div>

    <!-- Copyright -->
    <p class="copyright">
      &copy; {year}&nbsp;
      <a
        href="https://progsu.com"
        style="text-shadow: 0 0 8px rgba(147,51,234,0); transition: color 0.3s, text-shadow 0.3s;"
        onmouseover="this.style.color='rgba(255,255,255,1)';this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';"
        onmouseout="this.style.color='rgba(255,255,255,0.50)';this.style.textShadow='0 0 8px rgba(147,51,234,0)';"
      >
        progsu
      </a>
    </p>
  </div>
</footer>

<style>
  footer {
    position: relative;
    overflow: hidden;
    border-top: 1px solid transparent;
    margin-top: 6rem;
    padding: 3rem 2rem;
    text-align: center;
  }

  .binary-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    user-select: none;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.5rem 0;
  }

  .binary-row {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.10);
    text-shadow: 0 0 5px rgba(255, 255, 255, 0.10);
    white-space: nowrap;
    opacity: 0.03;
    letter-spacing: 0.15em;
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .social-link {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.70);
    text-decoration: none;
  }

  .copyright {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.50);
    margin: 0;
  }

  .copyright a {
    color: rgba(255, 255, 255, 0.50);
    text-decoration: none;
  }
</style>
