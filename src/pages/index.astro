---
import { getCollection } from "astro:content";
import HomeLayout from "@/layouts/HomeLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE_DESCRIPTION } from "@/consts";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const postCount = posts.length;
---

<HomeLayout>

  <!-- ═══════════════════════════════════════════════════
       HERO — full-screen cosmic constellation
  ═══════════════════════════════════════════════════ -->
  <section id="hero">

    <!-- Layer 1: deep nebula background -->
    <div class="h-nebula"></div>

    <!-- Layers 2–4: drifting starfields -->
    <div class="h-stars h-stars-far"></div>
    <div class="h-stars h-stars-mid"></div>
    <div class="h-stars h-stars-near"></div>

    <!-- Vignette -->
    <div class="h-vignette"></div>

    <!-- Constellation — 3D perspective wrapper -->
    <div class="h-world">

      <!-- SVG edges: center → clusters + inter-cluster dashes -->
      <svg class="h-svg" viewBox="0 0 1000 720" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <linearGradient id="edge-violet" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="rgba(168,85,247,.55)"/>
            <stop offset="100%" stop-color="rgba(168,85,247,.02)"/>
          </linearGradient>
          <linearGradient id="edge-violet-rev" x1="1" y1="0" x2="0" y2="0">
            <stop offset="0%" stop-color="rgba(168,85,247,.55)"/>
            <stop offset="100%" stop-color="rgba(168,85,247,.02)"/>
          </linearGradient>
          <linearGradient id="edge-cyan" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="rgba(34,211,238,.55)"/>
            <stop offset="100%" stop-color="rgba(34,211,238,.02)"/>
          </linearGradient>
          <linearGradient id="edge-lavender" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="rgba(216,180,254,.45)"/>
            <stop offset="100%" stop-color="rgba(216,180,254,.02)"/>
          </linearGradient>
        </defs>

        <!-- Center: 500, 360 -->
        <!-- code: 185, 185   career: 795, 170   build: 165, 555   community: 820, 540 -->

        <!-- Spokes from center -->
        <line x1="500" y1="360" x2="185" y2="185" stroke="url(#edge-violet)" stroke-width="1"/>
        <line x1="500" y1="360" x2="795" y2="170" stroke="url(#edge-cyan)" stroke-width="1.1"/>
        <line x1="500" y1="360" x2="165" y2="555" stroke="url(#edge-lavender)" stroke-width="1"/>
        <line x1="500" y1="360" x2="820" y2="540" stroke="url(#edge-violet-rev)" stroke-width=".9"/>

        <!-- Inter-cluster: faint dashes -->
        <line x1="185" y1="185" x2="795" y2="170" stroke="rgba(168,85,247,.07)" stroke-width=".5" stroke-dasharray="3 5"/>
        <line x1="185" y1="185" x2="165" y2="555" stroke="rgba(168,85,247,.06)" stroke-width=".5" stroke-dasharray="3 5"/>
        <line x1="795" y1="170" x2="820" y2="540" stroke="rgba(34,211,238,.08)" stroke-width=".5" stroke-dasharray="3 5"/>
        <line x1="165" y1="555" x2="820" y2="540" stroke="rgba(168,85,247,.06)" stroke-width=".5" stroke-dasharray="3 5"/>

        <!-- Cluster local micro-edges: code -->
        <line x1="185" y1="185" x2="120" y2="140" stroke="rgba(168,85,247,.28)" stroke-width=".5"/>
        <line x1="185" y1="185" x2="215" y2="125" stroke="rgba(168,85,247,.25)" stroke-width=".5"/>
        <line x1="185" y1="185" x2="140" y2="245" stroke="rgba(168,85,247,.22)" stroke-width=".5"/>

        <!-- Cluster local micro-edges: career (cyan) -->
        <line x1="795" y1="170" x2="855" y2="120" stroke="rgba(34,211,238,.32)" stroke-width=".6"/>
        <line x1="795" y1="170" x2="730" y2="108" stroke="rgba(34,211,238,.28)" stroke-width=".5"/>

        <!-- Cluster local micro-edges: build -->
        <line x1="165" y1="555" x2="100" y2="595" stroke="rgba(216,180,254,.25)" stroke-width=".5"/>
        <line x1="165" y1="555" x2="200" y2="615" stroke="rgba(216,180,254,.22)" stroke-width=".5"/>
        <line x1="165" y1="555" x2="115" y2="500" stroke="rgba(216,180,254,.2)" stroke-width=".4"/>

        <!-- Cluster local micro-edges: community -->
        <line x1="820" y1="540" x2="880" y2="495" stroke="rgba(168,85,247,.24)" stroke-width=".5"/>
        <line x1="820" y1="540" x2="870" y2="590" stroke="rgba(168,85,247,.22)" stroke-width=".5"/>
      </svg>

      <!-- ── CENTRAL ORB ─────────────────────────────── -->
      <div class="h-orb-wrap" aria-hidden="true">
        <div class="h-orb-bloom"></div>
        <div class="h-ring h-ring-1"></div>
        <div class="h-ring h-ring-2"></div>
        <div class="h-ring h-ring-3"></div>
        <div class="h-orb-core"></div>
      </div>

      <!-- ── CLUSTER: code (upper-left, violet) ─────── -->
      <div class="h-cluster" style="top: 21%; left: 16%;">
        <div class="h-node h-node-violet" style="animation-delay: 0s;"></div>
        <div class="h-cluster-label">code</div>
        <div class="h-cluster-count">{postCount > 0 ? `0${postCount} POSTS` : "— POSTS"}</div>
      </div>
      <!-- satellites -->
      <div class="h-sat" style="top: 15%; left: 10%; width: 5px; height: 5px; background: rgba(216,180,254,.75); box-shadow: 0 0 6px rgba(168,85,247,.5);" aria-hidden="true"></div>
      <div class="h-sat" style="top: 14%; left: 20%; width: 4px; height: 4px; background: rgba(216,180,254,.7); box-shadow: 0 0 5px rgba(168,85,247,.4);" aria-hidden="true"></div>
      <div class="h-sat" style="top: 31%; left: 12%; width: 5px; height: 5px; background: rgba(216,180,254,.7); box-shadow: 0 0 5px rgba(168,85,247,.4);" aria-hidden="true"></div>

      <!-- ── CLUSTER: career (upper-right, CYAN accent) ─ -->
      <div class="h-cluster" style="top: 19%; left: 76%;">
        <div class="h-node h-node-cyan" style="animation-delay: .7s;"></div>
        <div class="h-cluster-label">career</div>
        <div class="h-cluster-count" style="color: rgba(186,230,253,.75);">06 GUIDES</div>
      </div>
      <div class="h-sat" style="top: 13%; left: 83%; width: 5px; height: 5px; background: rgba(186,230,253,.75); box-shadow: 0 0 6px rgba(34,211,238,.5);" aria-hidden="true"></div>
      <div class="h-sat" style="top: 12%; left: 70%; width: 4px; height: 4px; background: rgba(186,230,253,.7); box-shadow: 0 0 5px rgba(34,211,238,.4);" aria-hidden="true"></div>

      <!-- ── CLUSTER: build (lower-left, lavender) ───── -->
      <div class="h-cluster" style="top: 68%; left: 12%; opacity: .88;">
        <div class="h-node h-node-violet" style="width: 18px; height: 18px; animation-delay: 1.4s;"></div>
        <div class="h-cluster-label">build</div>
        <div class="h-cluster-count">04 PROJECTS</div>
      </div>
      <div class="h-sat" style="top: 79%; left: 8%; width: 5px; height: 5px; background: rgba(216,180,254,.7); box-shadow: 0 0 5px rgba(168,85,247,.45);" aria-hidden="true"></div>
      <div class="h-sat" style="top: 80%; left: 19%; width: 4px; height: 4px; background: rgba(216,180,254,.65); box-shadow: 0 0 5px rgba(168,85,247,.4);" aria-hidden="true"></div>

      <!-- ── CLUSTER: community (lower-right, dim violet) -->
      <div class="h-cluster" style="top: 66%; left: 79%; opacity: .78;">
        <div class="h-node h-node-violet" style="width: 14px; height: 14px; animation-delay: 2.1s;"></div>
        <div class="h-cluster-label">community</div>
        <div class="h-cluster-count">1500+ BUILDERS</div>
      </div>
      <div class="h-sat" style="top: 60%; left: 87%; width: 4px; height: 4px; background: rgba(216,180,254,.6); box-shadow: 0 0 4px rgba(168,85,247,.38);" aria-hidden="true"></div>
      <div class="h-sat" style="top: 75%; left: 90%; width: 4px; height: 4px; background: rgba(216,180,254,.6); box-shadow: 0 0 4px rgba(168,85,247,.38);" aria-hidden="true"></div>

    </div><!-- /h-world -->

    <!-- ── EYEBROW (above fold, mono label) ────────── -->
    <div class="h-eyebrow" aria-hidden="true">an open blog &middot; by progsu</div>

    <!-- ── WORDMARK OVERLAY: mix-blend-exclusion cutout ── -->
    <div class="h-wordmark-wrap">
      <div class="h-wordmark-inner">
        <h1 class="h-headline glow-pulse-title" style="font-family: 'Noto Serif', Georgia, serif;">
          {["p","r","o","g","s","u"].map(char => (
            <span class="glitch-char">{char}</span>
          ))}<span class="h-slash"> / </span>blog
        </h1>
        <div class="h-phonetic">/prāg ˌes ˈyü/ &nbsp;<em>noun</em></div>
        <p class="h-desc">{SITE_DESCRIPTION}</p>
      </div>
    </div>

    <!-- ── SEARCH BAR ─────────────────────────────── -->
    <button
      class="h-search"
      aria-label="Search posts"
      onclick="(function(){ var o=document.getElementById('search-overlay'); if(o){ o.setAttribute('aria-hidden','false'); o.classList.add('open'); requestAnimationFrame(function(){ var i=document.getElementById('search-input'); if(i){ i.value=''; i.dispatchEvent(new Event('input')); i.focus(); } }); } })()"
    >
      <span class="h-search-icon" aria-hidden="true">
        <span class="h-si-circle"><span class="h-si-handle"></span></span>
      </span>
      <span class="h-search-placeholder">search {postCount} {postCount === 1 ? "post" : "posts"}...</span>
      <kbd class="h-search-kbd">⌘K</kbd>
    </button>

    <!-- ── STATS ROW ───────────────────────────────── -->
    <div class="h-stats">
      <span>{postCount} {postCount === 1 ? "post" : "posts"}</span>
      <span class="h-dot">·</span>
      <span>open source</span>
      <span class="h-dot">·</span>
      <span>atlanta, ga</span>
    </div>

    <!-- Scroll hint -->
    <div class="h-scroll" aria-hidden="true">scroll</div>

    <!-- ── SCROLL ARROW ────────────────────────────── -->
    <a href="#posts" class="h-arrow" aria-label="Scroll to posts">↓</a>

  </section>


  <!-- ═══════════════════════════════════════════════════
       POSTS — divider list
  ═══════════════════════════════════════════════════ -->
  <section id="posts" class="posts-section">
    <div class="posts-inner">

      <div class="posts-header float-in">
        <h2 class="section-heading">posts</h2>
        <span class="posts-count">{postCount} total</span>
      </div>

      {
        posts.length === 0 ? (
          <p class="empty-state float-in">no posts yet. check back soon.</p>
        ) : (
          <div class="post-list">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
        )
      }

      <div class="posts-cta float-in">
        <a
          href="https://progsu.com"
          class="cta-link"
          style="text-shadow: 0 0 8px rgba(147,51,234,0);"
          onmouseover="this.style.color='rgba(255,255,255,1)';this.style.textShadow='0 0 12px rgba(147,51,234,1), 0 0 30px rgba(147,51,234,0.6), 0 0 60px rgba(147,51,234,0.25)';"
          onmouseout="this.style.color='rgba(255,255,255,0.40)';this.style.textShadow='0 0 8px rgba(147,51,234,0)';"
        >
          ← back to progsu.com
        </a>
      </div>

    </div>
  </section>

</HomeLayout>

<style>
  /* ── Hero shell ──────────────────────────────────────── */
  #hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    background: #000000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Layer 1: nebula ─────────────────────────────────── */
  .h-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% 45%, rgba(76,29,149,.30), transparent 70%),
      radial-gradient(ellipse 50% 40% at 18% 72%, rgba(30,27,75,.45), transparent 65%),
      radial-gradient(ellipse 50% 40% at 82% 22%, rgba(13,42,90,.35), transparent 65%),
      linear-gradient(180deg, #020207 0%, #050514 50%, #020207 100%);
  }

  /* ── Layers 2–4: starfields ──────────────────────────── */
  .h-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .h-stars-far {
    background-image:
      radial-gradient(1px 1px at 12% 23%, rgba(255,255,255,.50), transparent),
      radial-gradient(1px 1px at 78% 67%, rgba(255,255,255,.40), transparent),
      radial-gradient(1px 1px at 34% 81%, rgba(255,255,255,.45), transparent),
      radial-gradient(1px 1px at 88% 14%, rgba(255,255,255,.50), transparent),
      radial-gradient(1px 1px at 5%  55%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 65% 30%, rgba(255,255,255,.30), transparent),
      radial-gradient(1px 1px at 25%  8%, rgba(255,255,255,.40), transparent),
      radial-gradient(1px 1px at 95% 88%, rgba(255,255,255,.40), transparent),
      radial-gradient(1px 1px at 45% 18%, rgba(255,255,255,.30), transparent),
      radial-gradient(1px 1px at 15% 75%, rgba(255,255,255,.50), transparent),
      radial-gradient(1px 1px at 55% 92%, rgba(255,255,255,.35), transparent),
      radial-gradient(1px 1px at 38% 45%, rgba(255,255,255,.25), transparent),
      radial-gradient(1px 1px at 72% 52%, rgba(255,255,255,.32), transparent),
      radial-gradient(1px 1px at 52% 38%, rgba(255,255,255,.28), transparent);
    background-size: 280px 280px;
    animation: driftFar 180s linear infinite;
    opacity: .65;
  }

  .h-stars-mid {
    background-image:
      radial-gradient(1.5px 1.5px at 22% 33%, rgba(255,255,255,.70), transparent),
      radial-gradient(1.5px 1.5px at 68% 57%, rgba(216,180,254,.60), transparent),
      radial-gradient(1.5px 1.5px at 84% 31%, rgba(255,255,255,.65), transparent),
      radial-gradient(1.5px 1.5px at  8% 65%, rgba(255,255,255,.60), transparent),
      radial-gradient(1.5px 1.5px at 92% 78%, rgba(186,230,253,.55), transparent),
      radial-gradient(1.5px 1.5px at 48% 88%, rgba(255,255,255,.50), transparent),
      radial-gradient(1.5px 1.5px at 33% 12%, rgba(255,255,255,.55), transparent),
      radial-gradient(1.5px 1.5px at 72%  8%, rgba(216,180,254,.50), transparent),
      radial-gradient(1.5px 1.5px at 58% 70%, rgba(216,180,254,.45), transparent);
    background-size: 380px 380px;
    animation: driftMid 120s linear infinite;
    opacity: .82;
  }

  .h-stars-near {
    background-image:
      radial-gradient(2px 2px at 18% 73%, rgba(255,255,255,.95) 0%, rgba(255,255,255,.4) 30%, transparent 60%),
      radial-gradient(2px 2px at 73% 22%, rgba(216,180,254,.85) 0%, rgba(216,180,254,.3) 30%, transparent 60%),
      radial-gradient(2px 2px at 87% 84%, rgba(255,255,255,.90) 0%, rgba(255,255,255,.35) 30%, transparent 60%),
      radial-gradient(2px 2px at  6% 26%, rgba(186,230,253,.80) 0%, rgba(186,230,253,.3) 30%, transparent 60%),
      radial-gradient(2px 2px at 62% 48%, rgba(255,255,255,.88) 0%, rgba(255,255,255,.3) 30%, transparent 60%);
    background-size: 480px 480px;
    animation: driftNear 80s linear infinite;
    opacity: .88;
  }

  /* ── Vignette ─────────────────────────────────────────── */
  .h-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 95% 80% at 50% 50%, transparent 40%, rgba(0,0,0,.60) 95%);
    pointer-events: none;
    z-index: 1;
  }

  /* ── 3D world ─────────────────────────────────────────── */
  .h-world {
    position: absolute;
    inset: 0;
    perspective: 1400px;
    perspective-origin: 50% 50%;
    z-index: 2;
  }

  /* ── SVG constellation ────────────────────────────────── */
  .h-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    transform-style: preserve-3d;
    transform: rotateX(6deg) rotateY(-2deg);
  }

  /* ── Central orb ─────────────────────────────────────── */
  .h-orb-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140px;
    height: 140px;
    pointer-events: none;
    z-index: 2;
  }

  .h-orb-bloom {
    position: absolute;
    inset: -60px;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, rgba(168,85,247,.20) 0%, rgba(168,85,247,.05) 30%, transparent 65%);
    filter: blur(20px);
  }

  .h-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(168,85,247,.16);
  }
  .h-ring-1 { inset: -28px; animation: pulseRing 4s ease-out infinite; }
  .h-ring-2 { inset: -48px; animation: pulseRing 4s ease-out infinite; animation-delay: 1.3s; }
  .h-ring-3 { inset: -68px; animation: pulseRing 4s ease-out infinite; animation-delay: 2.6s; border-color: rgba(168,85,247,.09); }

  .h-orb-core {
    position: absolute;
    inset: 28px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%,
      rgba(255,255,255,1)  0%,
      rgba(216,180,254,.95) 15%,
      rgba(168,85,247,.90)  40%,
      rgba(76,29,149,1)    75%,
      #1a0a2e 100%);
    box-shadow:
      0 0  50px rgba(168,85,247,.55),
      0 0 100px rgba(168,85,247,.28),
      0 0 150px rgba(168,85,247,.12),
      inset -10px -10px 20px rgba(0,0,0,.5);
  }

  /* ── Cluster nodes ───────────────────────────────────── */
  .h-cluster {
    position: absolute;
    text-align: center;
    transform: translateX(-50%);
    z-index: 3;
  }

  .h-node {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    margin: 0 auto;
    animation: nodeBreathe 5s ease-in-out infinite;
  }

  .h-node-violet {
    background: radial-gradient(circle at 35% 30%,
      rgba(255,255,255,1),
      rgba(216,180,254,1) 30%,
      rgba(168,85,247,1)  70%,
      rgba(76,29,149,1)  100%);
    box-shadow: 0 0 22px rgba(168,85,247,.85), 0 0 44px rgba(168,85,247,.38);
  }

  .h-node-cyan {
    background: radial-gradient(circle at 35% 30%,
      rgba(255,255,255,1),
      rgba(186,230,253,1) 30%,
      rgba(34,211,238,1)  70%,
      rgba(8,51,68,1)    100%);
    box-shadow: 0 0 22px rgba(34,211,238,.90), 0 0 44px rgba(34,211,238,.40);
  }

  .h-cluster-label {
    font-family: 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-size: .72rem;
    color: #fff;
    margin-top: .55rem;
    letter-spacing: .01em;
    text-shadow: 0 0 12px rgba(0,0,0,.8);
  }

  .h-cluster-count {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: .48rem;
    color: rgba(216,180,254,.70);
    letter-spacing: .13em;
    margin-top: .2rem;
  }

  /* Satellite dots */
  .h-sat {
    position: absolute;
    border-radius: 50%;
    z-index: 3;
    pointer-events: none;
  }

  /* ── Eyebrow ─────────────────────────────────────────── */
  .h-eyebrow {
    position: absolute;
    top: 14%;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: .55rem;
    color: rgba(216,180,254,.85);
    letter-spacing: .25em;
    text-align: center;
    text-shadow: 0 0 18px rgba(0,0,0,.9);
    z-index: 10;
    pointer-events: none;
    white-space: nowrap;
  }

  /* ── Wordmark overlay (mix-blend-exclusion) ───────────── */
  .h-wordmark-wrap {
    position: absolute;
    bottom: 26%;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 10;
    padding: 0 2rem;
    pointer-events: none;
    mix-blend-mode: exclusion;
    color: #fff;
  }

  .h-wordmark-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .h-headline {
    font-family: 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: #fff;
    margin: 0 0 .6rem;
  }

  .h-slash {
    color: rgba(255,255,255,.4);
    font-style: normal;
  }

  .h-phonetic {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: .7rem;
    letter-spacing: .12em;
    color: rgba(255,255,255,.70);
    margin-bottom: .5rem;
  }

  .h-desc {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: .875rem;
    font-weight: 300;
    color: rgba(255,255,255,.60);
    line-height: 1.6;
    max-width: 44ch;
    margin: 0 auto;
  }

  /* ── Search bar ──────────────────────────────────────── */
  .h-search {
    position: absolute;
    bottom: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 88%;
    max-width: 480px;
    display: flex;
    align-items: center;
    gap: .6rem;
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(168,85,247,.35);
    border-radius: .55rem;
    padding: .65rem .9rem;
    box-shadow:
      0 0 32px rgba(168,85,247,.14),
      0 8px 32px rgba(0,0,0,.50),
      inset 0 1px 0 rgba(255,255,255,.06);
    cursor: pointer;
    transition: border-color .2s, box-shadow .2s;
    z-index: 20;
  }

  .h-search:hover {
    border-color: rgba(168,85,247,.55);
    box-shadow:
      0 0 40px rgba(168,85,247,.22),
      0 8px 32px rgba(0,0,0,.50),
      inset 0 1px 0 rgba(255,255,255,.06);
  }

  /* CSS search icon */
  .h-search-icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
