---
import { NAV_LINKS, SITE_TITLE } from "@/consts";
---

<header style="position: fixed; top: 1.25rem; left: 1.5rem; right: 1.5rem; z-index: 30;">
  <nav style="display: flex; align-items: center; justify-content: space-between;">

    <!-- Left: brand -->
    <a
      href="/"
      style="text-decoration: none; font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: .15em; color: rgba(255,255,255,.65); text-transform: lowercase;"
    >
      progsu / blog
    </a>

    <!-- Right: links + kbd badge -->
    <div style="display: flex; align-items: center; gap: 1.2rem;">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            style="font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: .12em; color: rgba(255,255,255,.5); text-decoration: none; text-transform: lowercase; transition: color 0.15s ease;"
            onmouseover="this.style.color='rgba(255,255,255,.9)'"
            onmouseout="this.style.color='rgba(255,255,255,.5)'"
          >
            {link.label}
          </a>
        ))
      }
      <kbd id="search-trigger" class="kbd" role="button" tabindex="0" aria-label="Press / to search" style="cursor: pointer;">/</kbd>
    </div>

  </nav>
</header>
