---
import { NAV_LINKS, SITE_TITLE } from "@/consts";
---

<header class="sticky top-0 z-50 border-b border-accent-purple/30 bg-bg-deep/95 backdrop-blur-sm"
  style="box-shadow: 0 0 20px rgba(107, 34, 204, 0.3);">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a
      href="/"
      class="font-pixel text-xs text-accent-cyan glow-cyan hover:text-accent-pink hover:glow-pink transition-colors duration-200"
    >
      {SITE_TITLE}
    </a>
    <ul class="flex items-center gap-8">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-vt text-lg text-steel-blue hover:text-lavender transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
